# Kraftory Biergarten SEO & Performance .htaccess Configuration
# Place this file in your web root directory for Apache servers

# Enable Gzip Compression
<ifmodule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
  AddOutputFilterByType DEFLATE text/x-component text/x-cross-domain-policy
  # Don't compress images or other binary files
</ifmodule>

# Set Browser Cache
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS and JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  # Fonts
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  
  # Default
  ExpiresDefault "access plus 2 days"
</IfModule>

# Leverage Browser Caching
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|otf)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
  
  <FilesMatch "\.(html)$">
    Header set Cache-Control "max-age=3600, public, must-revalidate"
  </FilesMatch>
  
  # Add X-Frame-Options for security (anti-clickjacking)
  Header set X-Frame-Options "SAMEORIGIN"
  
  # Add X-Content-Type-Options to prevent MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # Add X-XSS-Protection header
  Header set X-XSS-Protection "1; mode=block"
  
  # Add Referrer-Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Enable HTTPS and force secure connections
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Remove www prefix (optional - choose one approach)
  # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  # RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
  
  # React Router: Route all requests to index.html for SPA routing
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Disable directory listing for security
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Optimize JPEG, PNG, GIF images (requires ImageMagick)
<IfModule mod_imageooptim.c>
  <FilesMatch "\.(jpg|jpeg|png|gif)$">
    SetHandler imageooptim-handler
  </FilesMatch>
</IfModule>

# Custom error pages (optional)
# ErrorDocument 404 /404.html
# ErrorDocument 500 /500.html

# Protect sensitive files
<FilesMatch "\.env|\.git|package\.json|package-lock\.json">
  Order allow,deny
  Deny from all
</FilesMatch>

# Allow robots.txt and sitemap.xml
<Files "robots.txt">
  Allow from all
</Files>

<Files "sitemap.xml">
  Allow from all
</Files>
